// This is your Prisma schema file
// BAD: everything in one giant schema file with no organization

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  name              String
  firstName         String?   // duplicate of name field
  lastName          String?   // duplicate of name field
  displayName       String?   // yet another name field
  role              String    @default("owner") // BAD: should be enum
  subscriptionTier  String    @default("free")  // BAD: should be enum
  isActive          Boolean   @default(true)
  isVerified        Boolean   @default(false)
  isPremium         Boolean   @default(false)   // duplicate of subscriptionTier
  isBanned          Boolean   @default(false)
  avatar            String?
  avatarThumbnail   String?   // YAGNI: never used
  coverImage        String?   // YAGNI: never used
  bio               String?
  phone             String?
  phoneVerified     Boolean   @default(false)
  address           String?
  addressLine2      String?   // YAGNI: never used
  city              String?
  state             String?
  country           String?   @default("US")
  zipCode           String?
  latitude          Float?    // YAGNI: never used
  longitude         Float?    // YAGNI: never used
  timezone          String?   @default("America/New_York")
  language          String?   @default("en")
  currency          String?   @default("USD") // YAGNI: app only supports USD
  referralCode      String?   @unique @default(uuid())
  referredById      String?
  referredBy        User?     @relation("UserReferrals", fields: [referredById], references: [id])
  referrals         User[]    @relation("UserReferrals")
  stripeCustomerId  String?
  stripeSubscriptionId String?
  lastLogin         DateTime?
  lastPasswordChange DateTime?
  loginCount        Int       @default(0)
  failedLoginAttempts Int     @default(0)
  lockedUntil       DateTime?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?   // BAD: storing 2FA secret in plain text
  resetPasswordToken String?
  resetPasswordExpiry DateTime?
  verificationToken String?
  verificationExpiry DateTime?
  preferences       Json?     // BAD: should be normalized
  metadata          Json?     // YAGNI: catch-all field added "just in case"
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime? // soft delete

  pets              Pet[]
  appointments      Appointment[]
  orders            Order[]
  reviews           Review[]
  notifications     Notification[]
  sessions          Session[]
  auditLogs         AuditLog[]
  sentMessages      Message[]    @relation("SentMessages")
  receivedMessages  Message[]    @relation("ReceivedMessages")

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ============================================
// PET MANAGEMENT
// ============================================

model Pet {
  id              String    @id @default(uuid())
  name            String
  species         String    // BAD: should be enum (dog, cat, bird, etc.)
  breed           String?
  gender          String?   // BAD: should be enum
  color           String?
  markings        String?   // YAGNI: never used
  microchipId     String?
  passportNumber  String?   // YAGNI: never used
  dateOfBirth     DateTime?
  age             Int?      // duplicate of dateOfBirth - inconsistency
  weight          Float?
  weightUnit      String?   @default("kg")
  height          Float?    // YAGNI: never used
  isNeutered      Boolean?
  isVaccinated    Boolean?  // YAGNI: too vague, should be per-vaccine
  isDeceased      Boolean   @default(false)
  deceasedAt      DateTime?
  status          String    @default("healthy") // BAD: should be enum
  imageUrl        String?
  imageUrls       String[]  // YAGNI: gallery, never implemented
  qrCode          String?   // YAGNI: never implemented
  notes           String?
  specialNeeds    String?
  dietaryRestrictions String?
  allergies       String?   // BAD: should be array/relation
  insuranceNumber String?   // YAGNI: never used
  insuranceProvider String? // YAGNI: never used
  adoptionDate    DateTime?
  purchasePrice   Float?    // YAGNI: sensitive and never used
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  metadata        Json?     // catch-all again
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  appointments    Appointment[]
  healthRecords   HealthRecord[]
  vaccinations    Vaccination[]
  medications     Medication[]
  weightLogs      WeightLog[]
  documents       Document[]
  reviews         Review[]

  @@index([ownerId])
  @@index([species])
  @@map("pets")
}

model HealthRecord {
  id          String   @id @default(uuid())
  petId       String
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  type        String   // "checkup" | "emergency" | "surgery" | "dental" etc - BAD: should be enum
  title       String
  description String?
  diagnosis   String?
  treatment   String?
  vetName     String?  // BAD: should be relation to Vet model
  vetClinic   String?  // BAD: should be relation
  cost        Float?
  currency    String?  @default("USD")
  notes       String?
  attachments String[]
  recordDate  DateTime
  nextVisit   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([petId])
  @@map("health_records")
}

model Vaccination {
  id              String   @id @default(uuid())
  petId           String
  pet             Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  vaccineName     String
  vaccineType     String?
  batchNumber     String?
  manufacturer    String?
  dateGiven       DateTime
  nextDueDate     DateTime?
  vetName         String?   // BAD: should be relation
  clinicName      String?   // BAD: should be relation
  certificate     String?
  sideEffects     String?
  notes           String?
  createdAt       DateTime  @default(now())

  @@index([petId])
  @@map("vaccinations")
}

model Medication {
  id            String    @id @default(uuid())
  petId         String
  pet           Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  name          String
  genericName   String?
  dosage        String
  dosageUnit    String?
  frequency     String    // "once daily" | "twice daily" etc - BAD: should be normalized
  route         String?   // "oral" | "topical" | "injection" - BAD: should be enum
  prescribedBy  String?   // BAD: should be relation
  startDate     DateTime
  endDate       DateTime?
  isOngoing     Boolean   @default(false)
  purpose       String?
  sideEffects   String?
  interactions  String?   // YAGNI: never actually checked
  refillDate    DateTime?
  refillCount   Int       @default(0)
  cost          Float?
  pharmacy      String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([petId])
  @@map("medications")
}

model WeightLog {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  weight    Float
  unit      String   @default("kg")
  notes     String?
  loggedAt  DateTime @default(now())

  @@index([petId])
  @@map("weight_logs")
}

// ============================================
// APPOINTMENTS
// ============================================

model Appointment {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  petId           String
  pet             Pet       @relation(fields: [petId], references: [id])
  serviceId       Int?      // optional link to service
  type            String    // BAD: should be enum
  status          String    @default("pending") // BAD: should be enum
  title           String?
  description     String?
  notes           String?
  vetName         String?   // BAD: should be relation
  clinicName      String?   // BAD: should be relation  
  clinicAddress   String?
  isVirtual       Boolean   @default(false)
  meetingLink     String?
  scheduledAt     DateTime
  duration        Int       @default(30) // minutes
  reminderSent    Boolean   @default(false)
  reminderSentAt  DateTime?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  completedAt     DateTime?
  cost            Float?
  paymentStatus   String?   // BAD: should be enum
  paymentId       String?
  rating          Int?
  feedback        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([petId])
  @@index([scheduledAt])
  @@map("appointments")
}

// ============================================
// PRODUCTS & ORDERS (e-commerce bolt-on)
// ============================================

model Product {
  id              String    @id @default(uuid())
  name            String
  slug            String    @unique
  description     String?
  shortDescription String?  // YAGNI: never used differently from description
  sku             String?   @unique
  barcode         String?   // YAGNI: never implemented
  category        String
  subcategory     String?
  brand           String?
  price           Float
  compareAtPrice  Float?
  cost            Float?    // YAGNI: margin calculation never implemented
  currency        String    @default("USD")
  stock           Int       @default(0)
  lowStockAlert   Int       @default(5)
  weight          Float?
  weightUnit      String?
  dimensions      Json?     // YAGNI: shipping calc never implemented
  imageUrl        String?
  imageUrls       String[]
  tags            String[]
  petSpecies      String[]  // which species this is for
  isActive        Boolean   @default(true)
  isFeatured      Boolean   @default(false)
  isDigital       Boolean   @default(false) // YAGNI: digital products never shipped
  requiresPrescription Boolean @default(false) // YAGNI: never validated
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orderItems      OrderItem[]
  reviews         Review[]

  @@index([category])
  @@index([isActive])
  @@map("products")
}

model Order {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  orderNumber     String    @unique @default(uuid())
  status          String    @default("pending") // BAD: should be enum
  subtotal        Float
  discount        Float     @default(0)
  tax             Float     @default(0)
  shipping        Float     @default(0)
  total           Float
  currency        String    @default("USD")
  paymentMethod   String?
  paymentId       String?
  paymentStatus   String?
  shippingAddress Json?
  billingAddress  Json?     // YAGNI: always same as shipping
  trackingNumber  String?
  shippingCarrier String?
  notes           String?
  cancelledAt     DateTime?
  cancellationReason String?
  refundedAt      DateTime?
  refundAmount    Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  price       Float    // price at time of order
  total       Float
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

// ============================================
// REVIEWS
// ============================================

model Review {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  petId       String?
  pet         Pet?     @relation(fields: [petId], references: [id])
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  rating      Int      // 1-5 BAD: no constraint
  title       String?
  content     String?
  isVerified  Boolean  @default(false)
  isApproved  Boolean  @default(false)
  helpfulCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@map("reviews")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // BAD: should be enum
  title     String
  body      String?
  data      Json?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ============================================
// MESSAGING (YAGNI - barely used)
// ============================================

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content     String
  isRead      Boolean  @default(false)
  readAt      DateTime?
  deletedBySender   Boolean @default(false)
  deletedByReceiver Boolean @default(false)
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

// ============================================
// MISC (YAGNI models)
// ============================================

model Document {
  id        String   @id @default(uuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  name      String
  type      String
  url       String
  size      Int?
  createdAt DateTime @default(now())

  @@map("documents")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@map("audit_logs")
}
